APP_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change-me
DB_NAME=apitool1

# JWT
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DAYS=365

# Security / hashing
BCRYPT_SALT_ROUNDS=10

# External services
WEATHER_API_KEY=replace-with-your-weather-api-key
OPENAI_API_KEY=

# App
CORS_ORIGINS=*
BASE_URL=http://localhost:3000/
ENABLE_SCHEDULER=true
UPLOAD_DIR=uploads
BLOB_READ_WRITE_TOKEN=

# Logging
LOG_LEVEL=INFO
JSON_LOGGING=false
